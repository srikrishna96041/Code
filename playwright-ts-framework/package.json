    "show-report": "npx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.36.0",
    "@playwright/mcp": "^0.0.68",
    "@types/node": "^25.3.1",
    "dotenv": "^16.0.0",
    "typescript": "^4.9.5"
  }
}
